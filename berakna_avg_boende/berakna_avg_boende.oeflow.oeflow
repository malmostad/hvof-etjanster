<EvaluatorDescriptor>
<evaluatorID>75345</evaluatorID>
<name>Kapitalskatt - inkl. make/maka</name>
<sortIndex>3</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.settextfieldvalueweightevaluator.SetTextFieldValueWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
<SetTextFieldValueWeightEvaluator>
<textFieldID>33691</textFieldID>
<expression><![CDATA[(($weight{vikt_kapitalinkomst} + $weight{vikt_kapitalinkomst_partner}) * 0.30) * (-1)]]></expression>
