<defaultQueryState>VISIBLE_REQUIRED</defaultQueryState>
<queryTypeID>com.nordicpeak.flowengine.queries.radiobuttonquery.RadioButtonQueryProviderModule</queryTypeID>
<exported>false</exported>
<EvaluatorDescriptors>
<EvaluatorDescriptor>
<evaluatorID>75322</evaluatorID>
<name>Sätt vikt för gift/partnerskap</name>
<comment>Är den sökande gift eller har registrerat partnerskap så blir den beräknade nettoinkomsten hälften av den sökandes och partners sammanlagda nettoinkomster.&#13;
Värdet blir därför 2 vid gift/partnerskap och 1 annars.</comment>
<sortIndex>1</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.setweightevaluator.SetWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
<SetWeightEvaluator>
<weightType>vikt_gift_partnerskap</weightType>
<useOnlyHighestWeight>false</useOnlyHighestWeight>
<AlternativeWeights>
<AlternativeWeight>
<alternativeID>56060</alternativeID>
<weight>2</weight>
</AlternativeWeight>
<AlternativeWeight>
<alternativeID>56061</alternativeID>
<weight>1</weight>
</AlternativeWeight>
</AlternativeWeights>
<evaluatorID>75322</evaluatorID>
<configURL>/ep/setweight/config/75322</configURL>
