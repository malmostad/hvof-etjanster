<EvaluatorDescriptor>
<evaluatorID>75356</evaluatorID>
<name>Beräknad omvårdnadsavgift</name>
<comment>Version 1:&#13;
$weight{vikt_nettoinkomst_delad} - $weight{vikt_hyresavgift} -  $weight{vikt_forbehallsbelopp}&#13;
&#13;
Version 2:&#13;
if(($weight{vikt_nettoinkomst_delad} - $weight{vikt_hyresavgift} - $weight{vikt_forbehallsbelopp}) &lt;= 0, 0, (min($weight{vikt_maxtaxa}, ($weight{vikt_nettoinkomst_delad} - $weight{vikt_hyresavgift} - $weight{vikt_forbehallsbelopp}))))</comment>
<sortIndex>1</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.settextfieldvalueweightevaluator.SetTextFieldValueWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
<SetTextFieldValueWeightEvaluator>
<textFieldID>33696</textFieldID>
<expression><![CDATA[if(($weight{vikt_nettoinkomst_delad} - $weight{vikt_hyresavgift} - $weight{vikt_forbehallsbelopp}) <= 0, 0, (min($weight{vikt_maxtaxa}, ($weight{vikt_nettoinkomst_delad} - $weight{vikt_hyresavgift} - $weight{vikt_forbehallsbelopp}))))]]></expression>
<displayDecimals>false</displayDecimals>
<invalidExpressionMessage>Fel vid beräkning av avgift för hemsjukvård.</invalidExpressionMessage>
<evaluatorID>75356</evaluatorID>
<configURL>/ep/settextfieldvalueweight/config/75356</configURL>
