<enabled>true</enabled>
<SetTextFieldValueWeightEvaluator>
<textFieldID>33664</textFieldID>
<expression><![CDATA[$weight{vikt_avgift_boende} + $weight{vikt_rantekostnad} + ($weight{vikt_boyta} * $weight{vikt_drift_schablon}/12)]]></expression>
