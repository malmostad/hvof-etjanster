<name>Beräknad total nettoinkomst per månad - inkl. make/maka</name>
<comment>OBS! Skatterna är adderade här eftersom dess motsvarande vikter är negativa.</comment>
<sortIndex>1</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.settextfieldvalueweightevaluator.SetTextFieldValueWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
<SetTextFieldValueWeightEvaluator>
<textFieldID>33666</textFieldID>
<expression><![CDATA[$weight{vikt_inkomst} + (($weight{vikt_kapitalinkomst} + $weight{vikt_kapitalinkomst_partner} + $weight{vikt_kapitalskatt})/12) + $weight{vikt_ej_skattepl_inkomst} + $weight{vikt_inkomst_partner} + $weight{vikt_ej_skattepl_inkomst_partner}]]></expression>
<displayDecimals>false</displayDecimals>
<invalidExpressionMessage>Fel vid beräkning av av nettoinkomst.</invalidExpressionMessage>
<evaluatorID>75286</evaluatorID>
<configURL>/ep/settextfieldvalueweight/config/75286</configURL>
