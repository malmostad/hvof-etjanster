<evaluatorID>75317</evaluatorID>
<name>Vikt för att visa text om hemsjukvård eller ej på övre del</name>
<sortIndex>1</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.settextfieldweightevaluator.SetTextFieldWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
