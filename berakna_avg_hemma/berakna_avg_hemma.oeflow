<QueryDescriptor>
<queryID>80449</queryID>
<name>Ange ditt civilstånd</name>
<sortIndex>0</sortIndex>
<defaultQueryState>VISIBLE_REQUIRED</defaultQueryState>
<queryTypeID>com.nordicpeak.flowengine.queries.radiobuttonquery.RadioButtonQueryProviderModule</queryTypeID>
<exported>false</exported>
<EvaluatorDescriptors>
<EvaluatorDescriptor>
<evaluatorID>75230</evaluatorID>
<name>Sätt vikt för civilstånd</name>
<comment>"Faktorerna" för ensamstående/gift men åtskild resp sambo/gift är egentligen 1,4789 resp 1,2066 (här sparade som heltal).&#13;
Minskar de två första med 1 (som påverkar beräkningarna mycket marginellt) för att få unika värden för varje val. Detta används sen för att avgöra om den sökande är gift eller ej (som i sin tur påverkar om inkomsterna ska summeras ihop eller ej).</comment>
<sortIndex>1</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.setweightevaluator.SetWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
<SetWeightEvaluator>
<weightType>vikt_civilstand</weightType>
<useOnlyHighestWeight>false</useOnlyHighestWeight>
<AlternativeWeights>
<AlternativeWeight>
<alternativeID>56051</alternativeID>
<weight>14788</weight>
</AlternativeWeight>
<AlternativeWeight>
<alternativeID>56052</alternativeID>
<weight>12065</weight>
</AlternativeWeight>
<AlternativeWeight>
<alternativeID>56053</alternativeID>
<weight>12066</weight>
</AlternativeWeight>
<AlternativeWeight>
<alternativeID>56054</alternativeID>
<weight>14789</weight>
</AlternativeWeight>
</AlternativeWeights>
<evaluatorID>75230</evaluatorID>
<configURL>/ep/setweight/config/75230</configURL>
