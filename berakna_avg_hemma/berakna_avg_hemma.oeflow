<QueryDescriptor>
<queryID>80469</queryID>
<name>Beräkning av betalningsförmåga/avgiftsutrymme (DOLD)</name>
<sortIndex>14</sortIndex>
<defaultQueryState>HIDDEN</defaultQueryState>
<queryTypeID>com.nordicpeak.flowengine.queries.textfieldquery.TextFieldQueryProviderModule</queryTypeID>
<exported>false</exported>
<EvaluatorDescriptors>
<EvaluatorDescriptor>
<evaluatorID>75294</evaluatorID>
<name>Betalningsförmåga/avgiftsutrymme (kr/mån)</name>
<comment>Här vill vi att summan ska stanna vid maxtaxan och vid 0 kr om avgiftsutrymmet (dvs betalningsförmågan) är negativt.</comment>
<sortIndex>1</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.settextfieldvalueweightevaluator.SetTextFieldValueWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
<SetTextFieldValueWeightEvaluator>
<textFieldID>33670</textFieldID>
<expression><![CDATA[if(($weight{vikt_nettoinkomst_delad} - $weight{vikt_boendekostnad_tillgodo} - $weight{vikt_forbehallsbelopp}) <= 0, 0, (min($weight{vikt_maxtaxa}, ($weight{vikt_nettoinkomst_delad} - $weight{vikt_boendekostnad_tillgodo} - $weight{vikt_forbehallsbelopp}))))]]></expression>
<displayDecimals>false</displayDecimals>
<invalidExpressionMessage>Fel vid beräkning av betalningsförmåga.</invalidExpressionMessage>
<evaluatorID>75294</evaluatorID>
<configURL>/ep/settextfieldvalueweight/config/75294</configURL>
<EvaluatorDescriptor>
<evaluatorID>75294</evaluatorID>
<name>Betalningsförmåga/avgiftsutrymme (kr/mån)</name>
<comment>Här vill vi att summan ska stanna vid maxtaxan och vid 0 kr om avgiftsutrymmet (dvs betalningsförmågan) är negativt.</comment>
<sortIndex>1</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.settextfieldvalueweightevaluator.SetTextFieldValueWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
</EvaluatorDescriptor>
</SetTextFieldValueWeightEvaluator>
</EvaluatorDescriptor>
<EvaluatorDescriptor>
<evaluatorID>75295</evaluatorID>
