<QueryDescriptor>
<queryID>80467</queryID>
<name>Tillgodoräknad boendekostnad per månad (DOLD)</name>
<comment>Tillgodoräknad boendekostnad är den andel av boendekostnaden (dvs avdrag) man räknar med vid beräkning av betalningsförmågan.&#13;
Om man bor tillsammans med någon, oavsett om man är gift eller sambo, så får man bara tillgodoräkna dig halva bostadskostnaden.</comment>
<sortIndex>12</sortIndex>
<defaultQueryState>HIDDEN</defaultQueryState>
<queryTypeID>com.nordicpeak.flowengine.queries.textfieldquery.TextFieldQueryProviderModule</queryTypeID>
<exported>false</exported>
<EvaluatorDescriptors>
<EvaluatorDescriptor>
<evaluatorID>75290</evaluatorID>
<name>Tillgodoräknad boendekostnad</name>
<comment>Tillgodoräknad boendekostnad (hela om ensamstående, halva om sambo/gift)</comment>
<sortIndex>1</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.settextfieldvalueweightevaluator.SetTextFieldValueWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
<SetTextFieldValueWeightEvaluator>
<textFieldID>33668</textFieldID>
<expression><![CDATA[$weight{vikt_boendekostnad}/$weight{vikt_sambo}]]></expression>
<displayDecimals>false</displayDecimals>
<invalidExpressionMessage>Fel vid beräkning av boendekostnad.</invalidExpressionMessage>
<evaluatorID>75290</evaluatorID>
<configURL>/ep/settextfieldvalueweight/config/75290</configURL>
