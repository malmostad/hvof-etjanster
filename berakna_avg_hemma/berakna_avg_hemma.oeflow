<enabled>true</enabled>
</EvaluatorDescriptor>
</SetTextFieldValueWeightEvaluator>
</EvaluatorDescriptor>
<EvaluatorDescriptor>
<evaluatorID>75241</evaluatorID>
<name>Personlig omvårdnad</name>
<comment>Formeln nedan gör följande:&#13;
1. Dela den summan av alla markerade kryssrutor  med den aktinella kryssrutans dividuella vikt&#13;
    x = $weight{vikt_summa_valda_omsorgsinsatser}/10)&#13;
&#13;
2. Avrunda med noll decimal:&#13;
   y = round(x, 0)&#13;
&#13;
3. Gör modulo 10 operation på resultatet:&#13;
  z=y%10&#13;
&#13;
