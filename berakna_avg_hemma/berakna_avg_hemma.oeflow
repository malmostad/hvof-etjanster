<QueryDescriptor>
<queryID>80472</queryID>
<name>Beräkning av justering för maxtaxa (DOLD)</name>
<sortIndex>17</sortIndex>
<defaultQueryState>HIDDEN</defaultQueryState>
<queryTypeID>com.nordicpeak.flowengine.queries.textfieldquery.TextFieldQueryProviderModule</queryTypeID>
<exported>false</exported>
<EvaluatorDescriptors>
<EvaluatorDescriptor>
<evaluatorID>75312</evaluatorID>
<name>Beräkning av justering för maxtaxa</name>
<comment>Om summan av alla avgifter är större än maxtaxan =&gt; returnera diffen som negativt värde, annars returnera noll.</comment>
<sortIndex>1</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.settextfieldvalueweightevaluator.SetTextFieldValueWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
<SetTextFieldValueWeightEvaluator>
<textFieldID>33675</textFieldID>
<expression><![CDATA[if((($weight{vikt_summa_avgifter} - $weight{vikt_maxtaxa}) > 0), (($weight{vikt_summa_avgifter} - $weight{vikt_maxtaxa})*(-1)), 0)]]></expression>
<displayDecimals>false</displayDecimals>
<invalidExpressionMessage>Fel vid beräkning av justering.</invalidExpressionMessage>
<evaluatorID>75312</evaluatorID>
<configURL>/ep/settextfieldvalueweight/config/75312</configURL>
