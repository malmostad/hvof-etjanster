<QueryDescriptor>
<queryID>80471</queryID>
<name>Beräkning av summa avgifter (DOLD)</name>
<sortIndex>16</sortIndex>
<defaultQueryState>HIDDEN</defaultQueryState>
<queryTypeID>com.nordicpeak.flowengine.queries.textfieldquery.TextFieldQueryProviderModule</queryTypeID>
<exported>false</exported>
<EvaluatorDescriptors>
<EvaluatorDescriptor>
<evaluatorID>75308</evaluatorID>
<name>Beräkning av summa avgifter - exkl hemsjukvård</name>
<comment>För serviceinsatser räknar vi enligt följande:&#13;
Inköp: 4,33 timmar/månad&#13;
Städ: 2,17 timmar/månad&#13;
Tvätt: 2,17 timmar/månad&#13;
&#13;
Avgiften för hemsjukvårdsuppdrag beräknas separat.&#13;
&#13;
OBS! Den redovisade summan stannar vid maxtaxan.</comment>
<sortIndex>0</sortIndex>
<evaluatorTypeID>com.nordicpeak.flowengine.evaluators.settextfieldvalueweightevaluator.SetTextFieldValueWeightEvaluationProviderModule</evaluatorTypeID>
<enabled>true</enabled>
<SetTextFieldValueWeightEvaluator>
<textFieldID>33673</textFieldID>
<expression><![CDATA[min($weight{vikt_maxtaxa},
(($weight{vikt_trygghetslarm_vald} * $weight{vikt_avg_trygghetslarm}) +
($weight{vikt_personlig_omv_vald} * $weight{vikt_avg_standardinsatser}) +
($weight{vikt_service_inkop_vald} * $weight{vikt_avg_standardinsatser} * 4.33) +
($weight{vikt_service_stadning_vald} * $weight{vikt_avg_standardinsatser} * 2.17) +
($weight{vikt_service_tvatt_vald} * $weight{vikt_avg_standardinsatser} * 2.17) +
($weight{vikt_dagverksamhet_vald} * $weight{vikt_avg_standardinsatser})))]]></expression>
<displayDecimals>false</displayDecimals>
<invalidExpressionMessage>Fel vid beräkning av summa avgifter.</invalidExpressionMessage>
<evaluatorID>75308</evaluatorID>
<configURL>/ep/settextfieldvalueweight/config/75308</configURL>
<EvaluatorDescriptor>
<evaluatorID>75308</evaluatorID>
